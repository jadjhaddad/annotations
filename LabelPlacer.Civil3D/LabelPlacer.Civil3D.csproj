<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="15.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Import Project="$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props"
          Condition="Exists('$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props')" />

  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <Platform Condition=" '$(Platform)' == '' ">AnyCPU</Platform>
    <ProjectGuid>{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}</ProjectGuid>
    <OutputType>Library</OutputType>
    <RootNamespace>LabelPlacer.Civil3D</RootNamespace>
    <AssemblyName>LabelPlacer.Civil3D</AssemblyName>
    <TargetFrameworkVersion>v4.8</TargetFrameworkVersion>
    <LangVersion>latest</LangVersion>
    <Deterministic>true</Deterministic>
    <FileAlignment>512</FileAlignment>
    <NuGetPackageImportStamp>
    </NuGetPackageImportStamp>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|AnyCPU' ">
    <DebugSymbols>true</DebugSymbols>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <OutputPath>bin\Debug\</OutputPath>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
    <WarningLevel>4</WarningLevel>
    <PlatformTarget>x64</PlatformTarget>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU' ">
    <DebugType>pdbonly</DebugType>
    <Optimize>true</Optimize>
    <OutputPath>bin\Release\</OutputPath>
    <DefineConstants>TRACE</DefineConstants>
    <WarningLevel>4</WarningLevel>
    <PlatformTarget>x64</PlatformTarget>
  </PropertyGroup>

  <!--
    Civil 3D install path.  The OE 2024 DLLs are .NET-Framework-compatible
    and compile cleanly against net48.  Override via Directory.Build.props.user
    if your installation differs.
  -->
  <PropertyGroup>
    <Civil3DOEDir Condition="'$(Civil3DOEDir)' == ''">C:\Program Files\Autodesk\Civil 3D 2024 Object Enabler</Civil3DOEDir>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="System" />
    <Reference Include="System.Core" />

    <!-- AutoCAD .NET managed API — NuGet packages from BridgeAutomation repo -->
    <Reference Include="AcDbMgd">
      <HintPath>..\..\BridgeAutomation\packages\AutoCAD.NET.Model.24.0.0\lib\net47\AcDbMgd.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="AcCoreMgd">
      <HintPath>..\..\BridgeAutomation\packages\AutoCAD.NET.Core.24.0.0\lib\net47\AcCoreMgd.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="AcMgd">
      <HintPath>..\..\BridgeAutomation\packages\AutoCAD.NET.24.0.0\lib\net47\AcMgd.dll</HintPath>
      <Private>False</Private>
    </Reference>

    <!-- Civil 3D managed API — 2024 OE is .NET Framework compatible -->
    <Reference Include="AeccDbMgd">
      <HintPath>$(Civil3DOEDir)\AeccDbMgd.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="AecBaseMgd">
      <HintPath>$(Civil3DOEDir)\AecBaseMgd.dll</HintPath>
      <Private>False</Private>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <Compile Include="CogoLabelArrangerCommand.cs" />
    <Compile Include="Properties\AssemblyInfo.cs" />
  </ItemGroup>

  <ItemGroup>
    <None Include="packages.config" />
  </ItemGroup>

  <!-- LabelPlacer engine: built first, output copied to bin\ -->
  <ItemGroup>
    <ProjectReference Include="..\LabelPlacer\LabelPlacer.csproj" />
  </ItemGroup>

  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />

  <!-- NuGet restore targets (generated by VS NuGet) -->
  <Import Project="..\packages\AutoCAD.NET.24.0.0\build\net47\AutoCAD.NET.targets"
          Condition="Exists('..\packages\AutoCAD.NET.24.0.0\build\net47\AutoCAD.NET.targets')" />
</Project>
